# Server Configuration
PORT=3001
NODE_ENV=development

# Database (Required)
DATABASE_URL=postgresql://user:password@localhost:5432/thebrain

# Qwen 3.5-35B Configuration
# Use OpenRouter, Together AI, or any OpenAI-compatible provider
QWEN_BASE_URL=https://openrouter.ai/api/v1
QWEN_API_KEY=your_openrouter_api_key

# Or use Replit AI integrations
# AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1
# AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key

# MCP Server Configuration
# Brave Search (Optional - enables web search)
BRAVE_API_KEY=your_brave_api_key

# Supabase (Optional - enables keyless database access)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token

# Aider Configuration
AIDER_MODEL=qwen/qwen3.5-35b
PROJECT_ROOT=/path/to/your/project
